{
    "version": 2,
    "buildCommand": "pnpm run build",
    "outputDirectory": "public/out",
    "rewrites": [
        { "source": "/out/(.*)", "destination": "/out/$1" },
        { "source": "/(.*)", "destination": "/index.html" }
    ],
    "framework": "vite",
    "github": {
        "silent": true
    }
}
