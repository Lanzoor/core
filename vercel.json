{
    "version": 2,
    "buildCommand": "pnpm run build",
    "outputDirectory": "public/out",
    "framework": "vite",
    "rewrites": [
        {
            "source": "/out/(.*)",
            "destination": "/out/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "github": {
        "silent": true
    }
}
