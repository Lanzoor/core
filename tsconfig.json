{
    "compilerOptions": {
        "rootDir": "src",
        "outDir": "public/out",

        "target": "ES2020",
        "module": "ES2020",

        "lib": ["esnext", "dom"],

        "declaration": false,
        "sourceMap": false,
        "removeComments": true,

        "strict": true,
        "skipLibCheck": true
    },

    "include": ["src/**/*.ts", "public/**/*.ts"]
}
