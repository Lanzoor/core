{
    "compilerOptions": {
        "outDir": "out",

        "target": "ES2020",
        "module": "ES2020",

        "lib": ["esnext", "dom"],

        "declaration": false,
        "sourceMap": false,
        "removeComments": true,

        "strict": true,
        "skipLibCheck": true,

        "jsx": "react-jsx",

        "noEmit": true,
        "types": ["react", "react-dom"]
    },

    "exclude": ["api", "node_modules"]
}
