{
    "compilerOptions": {
        "rootDir": "src",
        "outDir": "public/out",

        "target": "ES2020",
        "module": "ES2020",
        "moduleResolution": "bundler",

        "lib": ["esnext", "dom"],

        "jsx": "react",
        "types": ["react", "react-dom"],

        "strict": true,
        "skipLibCheck": true
    },
    "include": ["src/**/*.ts", "src/**/*.tsx", "public/**/*.ts", "public/**/*.ts", "public/legacy/profile-old/profile-old.ts"]
}
