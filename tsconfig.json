{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "Node",
        "strict": true,

        "rootDir": "./src",
        "outDir": "./public/out",

        "allowJs": false,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "isolatedModules": true
    },

    "include": ["src/**/*.ts"],
    "exclude": ["node_modules"]
}
